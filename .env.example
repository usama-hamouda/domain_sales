# Copy to .env in project root (domain-sales/.env)

# Server (VPS: PORT=3001 behind nginx on port 8080 — http://YOUR_VPS_IP:8080)
PORT=3001
HOST=127.0.0.1
NODE_ENV=production

# ZFBot credentials (optional — processing on Windows)
ZFBOT_EMAIL=
ZFBOT_PASSWORD=

# Python / Chrome (Windows local processing)
# PYTHON_EXE=python
# CHROME_DEBUG_PORT=9223
# CHROME_EXE=C:\Program Files\Google\Chrome\Application\chrome.exe
# CHROME_USER_DATA=C:\ChromeDebug

# Linux VPS Chrome (only if you run processors on the server)
# CHROME_EXE=/usr/bin/google-chrome
# CHROME_USER_DATA=/var/lib/domain-sales/chrome-profile

# ── Auto-sync local DB → VPS (Windows only — do NOT enable on the VPS itself) ──
# Requires OpenSSH client (ssh/scp) on Windows and passwordless SSH to the VPS.
# REMOTE_DB_SYNC_ENABLED=1
# REMOTE_SSH_HOST=YOUR_VPS_IP
# REMOTE_SSH_USER=your_linux_user
# REMOTE_DB_PATH=/var/www/domain-sales/backend/domain_sales.db
# REMOTE_SSH_KEY_PATH=C:\Users\Admin\.ssh\id_rsa
# REMOTE_SERVICE_MANAGE=1
# REMOTE_DB_SYNC_DEBOUNCE_MS=4000

# ── API sync local changes → VPS (recommended — no full DB upload) ──
# Windows: pushes row-level changes after each write (debounced).
# VPS: set the same SYNC_API_TOKEN to accept changes at POST /api/sync/apply
# REMOTE_API_SYNC_ENABLED=1
# REMOTE_API_URL=http://YOUR_VPS_IP:8080
# REMOTE_API_TOKEN=choose-a-long-random-secret
# SYNC_API_TOKEN=choose-a-long-random-secret
# REMOTE_API_SYNC_DEBOUNCE_MS=4000
# REMOTE_API_SYNC_BATCH_SIZE=250
# REMOTE_API_PULL_INTERVAL_MS=15000
# REMOTE_API_PULL_BATCH_SIZE=400
